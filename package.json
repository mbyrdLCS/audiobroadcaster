{
  "name": "audio-broadcaster",
  "version": "1.4.0",
  "description": "An Electron app for broadcasting audio",
  "author": "MJB",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:whisper": "./scripts/build-whisper.sh"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.5.4"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "electron": "^28.2.3",
    "electron-builder": "^24.9.1",
    "socket.io-client": "^4.8.3"
  },
  "build": {
    "appId": "com.mjb.audiobroadcaster",
    "productName": "Audio Broadcaster",
    "afterSign": "scripts/notarize.js",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "gatekeeperAssess": false,
      "identity": "BAIPHONES LLC (QLSQ27WR56)",
      "minimumSystemVersion": "10.15"
    },
    "files": [
      "main.js",
      "preload.js",
      "public/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/whisper",
        "to": "whisper"
      },
      {
        "from": "THIRD_PARTY_LICENSES.md",
        "to": "THIRD_PARTY_LICENSES.md"
      }
    ],
    "asar": true,
    "electronVersion": "28.3.3"
  }
}
